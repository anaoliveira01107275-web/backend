
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Alunos {
  id           Int            @id @default(autoincrement())
  nome         String
  idade        Int
  cpf          Int            @unique
  email        String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  cursos AlunosCursos[]
}

model Cursos {
  id           Int            @id @default(autoincrement())
  nome         String
  professor    String?
  cargaHoraria Int
  descricao    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  alunos AlunosCursos[]
}

model AlunosCursos {
  id        Int      @id @default(autoincrement())
  alunosId  Int
  cursosId  Int
  alunos    Alunos   @relation(fields: [alunosId], references: [id])
  cursos    Cursos   @relation(fields: [cursosId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Funcionarios{
  id Int @id @default(autoincrement())
  nome String
  email String @unique
  senha String 
  admin Boolean @default(false)
  createdAt  DateTime @default(now())
  updateAt DateTime @updatedAt
}